{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Auditex Report Pack",
  "type": "object",
  "required": ["summary", "findings", "evidence_paths"],
  "properties": {
    "schema_version": { "type": "string" },
    "summary": {
      "type": "object",
      "required": ["tenant_name", "overall_status", "finding_count", "blocker_count"],
      "properties": {
        "tenant_name": { "type": "string" },
        "overall_status": { "type": "string" },
        "finding_count": { "type": "integer" },
        "blocker_count": { "type": "integer" },
        "severity_counts": { "type": "object" },
        "status_counts": { "type": "object" },
        "open_count": { "type": "integer" },
        "accepted_count": { "type": "integer" },
        "diff_summary": { "type": "object" }
      }
    },
    "privacy": { "type": "object" },
    "artifact_map": { "type": "object" },
    "findings": {
      "type": "array",
      "items": { "type": "object" }
    },
    "action_plan": {
      "type": "array",
      "items": { "type": "object" }
    },
    "evidence_paths": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
