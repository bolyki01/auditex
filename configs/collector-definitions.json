{
  "collectors": {
    "identity": {
      "enabled": true,
      "description": "Core tenant, user, groups, and application posture data from Microsoft Entra",
      "required_permissions": [
        "Directory.Read.All",
        "User.Read.All",
        "Group.Read.All",
        "Application.Read.All"
      ],
      "query_plan": [
        "organization",
        "domains",
        "users",
        "groups",
        "applications",
        "servicePrincipals",
        "roleDefinitions",
        "roleAssignments"
      ]
    },
    "security": {
      "enabled": true,
      "description": "Sign-in and directory audit signals from Microsoft Graph",
      "required_permissions": [
        "AuditLog.Read.All"
      ],
      "query_plan": [
        "directoryAudits",
        "signIns"
      ]
    },
    "conditional_access": {
      "enabled": true,
      "description": "Conditional Access policy targeting and advanced policy dependency surfaces.",
      "required_permissions": [
        "Policy.Read.All",
        "Directory.Read.All"
      ],
      "query_plan": [
        "conditionalAccessPolicies",
        "namedLocations",
        "authenticationStrengthPolicies",
        "authenticationContextClassReferences"
      ]
    },
    "defender": {
      "enabled": true,
      "description": "Defender alerts, incidents, and security score posture.",
      "required_permissions": [
        "SecurityEvents.Read.All",
        "SecurityIncident.Read.All",
        "SecurityActions.Read.All"
      ],
      "query_plan": [
        "securityAlerts",
        "defenderIncidents",
        "secureScores",
        "secureScoreControlProfiles"
      ]
    },
    "service_health": {
      "enabled": true,
      "description": "Microsoft 365 service health, issues, and message center posture.",
      "required_permissions": [
        "ServiceHealth.Read.All",
        "ServiceMessage.Read.All"
      ],
      "query_plan": [
        "healthOverviews",
        "serviceIssues",
        "messages"
      ]
    },
    "auth_methods": {
      "enabled": true,
      "description": "Authentication methods policy and MFA registration posture",
      "required_permissions": [
        "Policy.Read.All",
        "Reports.Read.All"
      ],
      "query_plan": [
        "authenticationMethodsPolicy",
        "userRegistrationDetails"
      ]
    },
    "reports_usage": {
      "enabled": true,
      "description": "Microsoft 365 usage report samples for Exchange, SharePoint, and OneDrive.",
      "required_permissions": [
        "Reports.Read.All"
      ],
      "query_plan": [
        "office365ActiveUserCounts",
        "sharePointSiteUsageDetail",
        "oneDriveUsageAccountDetail",
        "mailboxUsageDetail"
      ]
    },
    "external_identity": {
      "enabled": true,
      "description": "Cross-tenant access, invitation policy, and authentication flow posture.",
      "required_permissions": [
        "Policy.Read.All",
        "Directory.Read.All"
      ],
      "query_plan": [
        "crossTenantAccessPolicy",
        "authorizationPolicy",
        "authenticationFlowsPolicy"
      ]
    },
    "consent_policy": {
      "enabled": true,
      "description": "Admin consent workflow, user consent, and permission grant policy posture.",
      "required_permissions": [
        "Policy.Read.All",
        "Directory.Read.All"
      ],
      "query_plan": [
        "adminConsentRequestPolicy",
        "permissionGrantPolicies",
        "authorizationPolicy"
      ]
    },
    "dns_posture": {
      "enabled": true,
      "description": "Email-authentication DNS posture (SPF, DKIM, DMARC, MTA-STS, BIMI) for verified tenant domains.",
      "required_permissions": [
        "Directory.Read.All"
      ],
      "query_plan": [
        "domains",
        "domainPosture"
      ]
    },
    "cross_tenant_access": {
      "enabled": true,
      "description": "Microsoft Entra cross-tenant access policy: default and partner-scoped B2B Collaboration / B2B Direct Connect access plus inbound trust acceptance.",
      "required_permissions": [
        "Policy.Read.All"
      ],
      "query_plan": [
        "crossTenantAccessPolicy",
        "defaultPolicy",
        "partnerConfigurations"
      ]
    },
    "domains_hybrid": {
      "enabled": true,
      "description": "Domain posture and sampled hybrid sync signals.",
      "required_permissions": [
        "Directory.Read.All"
      ],
      "query_plan": [
        "organization",
        "domains",
        "syncSampleUsers"
      ]
    },
    "intune": {
      "enabled": true,
      "description": "Intune/Endpoint Management posture and device state",
      "required_permissions": [
        "DeviceManagementManagedDevices.Read.All",
        "DeviceManagementConfiguration.Read.All",
        "DeviceManagementApps.Read.All"
      ],
      "query_plan": [
        "managedDevices",
        "deviceCompliancePolicies",
        "deviceConfigurationProfiles"
      ]
    },
    "sharepoint": {
      "enabled": true,
      "description": "SharePoint and OneDrive tenant inventory posture",
      "required_permissions": [
        "Sites.Read.All"
      ],
      "query_plan": [
        "sharePointSettings",
        "sites"
      ]
    },
    "sharepoint_access": {
      "enabled": true,
      "description": "SharePoint and OneDrive sharing posture plus sampled site permission inventory",
      "required_permissions": [
        "Sites.Read.All"
      ],
      "query_plan": [
        "sharePointSettings",
        "sites",
        "sitePermissionsBySite"
      ]
    },
    "power_platform": {
      "enabled": false,
      "description": "Microsoft Power Platform admin posture: environments, DLP policies, and tenant settings (capability-gated; requires admin token).",
      "required_permissions": [],
      "query_plan": [
        "environments",
        "dlpPolicies",
        "tenantSettings"
      ]
    },
    "sentinel_xdr": {
      "enabled": false,
      "description": "Microsoft Sentinel / unified XDR posture via Graph (capability-gated).",
      "required_permissions": [
        "SecurityIncident.Read.All",
        "SecurityEvents.Read.All"
      ],
      "query_plan": [
        "xdrIncidents",
        "xdrAlerts"
      ]
    },
    "defender_cloud_apps": {
      "enabled": false,
      "description": "Microsoft Defender for Cloud Apps (CASB) posture (capability-gated; E5/Defender required).",
      "required_permissions": [
        "CloudApp-Discovery.Read.All",
        "Application.Read.All"
      ],
      "query_plan": [
        "cloudAppSecurityProfiles",
        "appConsentRequests"
      ]
    },
    "copilot_governance": {
      "enabled": false,
      "description": "Microsoft 365 Copilot governance posture (capability-gated; Copilot license required).",
      "required_permissions": [
        "Reports.Read.All",
        "AiEnterpriseInteraction.Read.All"
      ],
      "query_plan": [
        "copilotAdminSettings",
        "copilotUsageReports"
      ]
    },
    "onedrive_posture": {
      "enabled": true,
      "description": "OneDrive sharing posture and sampled personal site inventory.",
      "required_permissions": [
        "Sites.Read.All"
      ],
      "query_plan": [
        "sharePointSettings",
        "sites",
        "oneDriveSites"
      ]
    },
    "teams": {
      "enabled": true,
      "description": "Teams and channel configuration",
      "required_permissions": [
        "Team.ReadBasic.All",
        "Channel.ReadBasic.All",
        "Group.Read.All"
      ],
      "query_plan": [
        "teamGroups",
        "teamChannels",
        "teamsByTeam"
      ]
    },
    "teams_policy": {
      "enabled": true,
      "description": "Teams federation, messaging, meeting, and app policy posture",
      "required_permissions": [
        "TeamSettings.Read.All"
      ],
      "query_plan": [
        "tenantFederationConfiguration",
        "messagingPolicies",
        "meetingPolicies",
        "appPermissionPolicies",
        "appSetupPolicies"
      ],
      "command_collectors": [
        {
          "name": "tenantFederationConfiguration",
          "category": "policy",
          "commands": [
            "Get-CsTenantFederationConfiguration | Select-Object AllowFederatedUsers,AllowTeamsConsumer,AllowPublicUsers"
          ]
        },
        {
          "name": "messagingPolicies",
          "category": "policy",
          "commands": [
            "Get-CsTeamsMessagingPolicy | Select-Object Identity,AllowOwnerDeleteMessage,AllowUserDeleteMessage,AllowUserEditMessage"
          ]
        },
        {
          "name": "meetingPolicies",
          "category": "policy",
          "commands": [
            "Get-CsTeamsMeetingPolicy | Select-Object Identity,AllowCloudRecording,AllowIPVideo,ScreenSharingMode"
          ]
        },
        {
          "name": "appPermissionPolicies",
          "category": "policy",
          "commands": [
            "Get-CsTeamsAppPermissionPolicy | Select-Object Identity,GlobalCatalogAppsType"
          ]
        },
        {
          "name": "appSetupPolicies",
          "category": "policy",
          "commands": [
            "Get-CsTeamsAppSetupPolicy | Select-Object Identity,AllowSideLoading"
          ]
        }
      ]
    },
    "app_credentials": {
      "enabled": true,
      "description": "Application & service principal credential hygiene: secrets, certificates, redirect URIs, federated identity credentials, ownership, and audience drift.",
      "required_permissions": [
        "Application.Read.All",
        "Directory.Read.All"
      ],
      "query_plan": [
        "applicationCredentials",
        "servicePrincipalCredentials"
      ]
    },
    "app_consent": {
      "enabled": true,
      "description": "Enterprise application delegated consent, owners, and app role assignments",
      "required_permissions": [
        "Directory.Read.All",
        "DelegatedPermissionGrant.Read.All",
        "AppRoleAssignment.ReadWrite.All"
      ],
      "query_plan": [
        "servicePrincipals",
        "oauth2PermissionGrants",
        "servicePrincipalOwners",
        "servicePrincipalAppRoleAssignments"
      ]
    },
    "licensing": {
      "enabled": true,
      "description": "Subscribed SKU inventory and sampled direct and group-based license assignment posture",
      "required_permissions": [
        "Organization.Read.All",
        "Directory.Read.All"
      ],
      "query_plan": [
        "subscribedSkus",
        "licensedUsers",
        "licensedGroups"
      ]
    },
    "identity_governance": {
      "enabled": true,
      "description": "Identity governance, entitlement management, and privileged schedule inventory",
      "required_permissions": [
        "AccessReview.Read.All",
        "EntitlementManagement.Read.All",
        "RoleManagement.Read.Directory",
        "Directory.Read.All"
      ],
      "query_plan": [
        "accessReviews",
        "entitlementCatalogs",
        "accessPackages",
        "roleAssignmentSchedules",
        "roleEligibilitySchedules",
        "administrativeUnits"
      ]
    },
    "intune_depth": {
      "enabled": true,
      "description": "Deeper Intune policy, script, app protection, and sampled assignment inventory",
      "required_permissions": [
        "DeviceManagementConfiguration.Read.All",
        "DeviceManagementApps.Read.All"
      ],
      "query_plan": [
        "deviceConfigurations",
        "groupPolicyConfigurations",
        "deviceManagementScripts",
        "androidManagedAppProtections",
        "iosManagedAppProtections",
        "deviceConfigurationAssignments"
      ]
    },
    "purview": {
      "enabled": false,
      "description": "Purview posture and export readiness (adapter-backed, optional on inventory)",
      "required_permissions": [
        "AuditLog.Read.All"
      ],
      "query_plan": [
        "purviewReadiness",
        "retentionLabels",
        "retentionPolicies",
        "dlpPolicies",
        "auditLogJobs",
        "auditLogExports"
      ],
      "command_collectors": [
        {
          "name": "purviewReadiness",
          "category": "readiness",
          "commands": [
            "m365 purview auditlog list --output json --help",
            "m365 purview"
          ]
        },
        {
          "name": "retentionLabels",
          "category": "policy",
          "commands": [
            "m365 purview retentionlabel list --output json",
            "m365 purview retention label list --output json"
          ]
        },
        {
          "name": "retentionPolicies",
          "category": "policy",
          "commands": [
            "m365 purview retentionpolicy list --output json",
            "m365 purview retention policy list --output json"
          ]
        },
        {
          "name": "dlpPolicies",
          "category": "policy",
          "commands": [
            "m365 purview dlp policy list --output json",
            "m365 purview dlppolicy list --output json"
          ]
        },
        {
          "name": "auditLogJobs",
          "category": "export",
          "plane": "export",
          "commands": [
            "m365 purview auditlog list --output json",
            "m365 purview audit-log search --output json"
          ]
        },
        {
          "name": "auditLogExports",
          "category": "export",
          "plane": "export",
          "commands": [
            "m365 purview auditlog export create --output json --help",
            "m365 purview auditlog list --output json --top 100"
          ]
        }
      ]
    },
    "ediscovery": {
      "enabled": false,
      "description": "eDiscovery case/search/operation inventory and export metadata (adapter + graph)",
      "required_permissions": [
        "eDiscovery.Read.All",
        "SecurityIncident.Read.All"
      ],
      "query_plan": [
        "cases",
        "holdPackages",
        "searches",
        "operations",
        "caseOverview",
        "searchList",
        "exportJobs",
        "reviewSets",
        "holdList"
      ],
      "command_collectors": [
        {
          "name": "caseOverview",
          "category": "inventory",
          "commands": [
            "m365 purview ediscoverycase list --output json",
            "m365 purview ediscovery case list --output json"
          ]
        },
        {
          "name": "searchList",
          "category": "inventory",
          "commands": [
            "m365 purview ediscoverysearch list --output json",
            "m365 purview ediscovery search list --output json"
          ]
        },
        {
          "name": "exportJobs",
          "category": "export",
          "plane": "export",
          "commands": [
            "m365 purview ediscoveryexport list --output json",
            "m365 purview ediscovery export list --output json"
          ]
        },
        {
          "name": "reviewSets",
          "category": "export",
          "plane": "export",
          "commands": [
            "m365 purview reviewset list --output json",
            "m365 purview ediscovery reviewset list --output json"
          ]
        },
        {
          "name": "holdList",
          "category": "inventory",
          "commands": [
            "m365 purview hold list --output json",
            "m365 purview legal hold list --output json"
          ]
        }
      ]
    },
    "exchange": {
      "enabled": false,
      "description": "Optional Exchange posture and readiness checks through Microsoft 365 CLI command execution",
      "required_permissions": [],
      "query_plan": [
        "exchangeConnectivityCheck",
        "exchangeTenantInfo",
        "mailboxCount",
        "mailboxQuotaStatus",
        "mailboxStorage",
        "mailActivityCounts",
        "roomLists"
      ],
      "command_collectors": [
        {
          "name": "exchangeConnectivityCheck",
          "category": "readiness",
          "commands": [
            "m365 status --output json",
            "m365 tenant info get --output json"
          ]
        },
        {
          "name": "exchangeTenantInfo",
          "category": "posture",
          "commands": [
            "m365 tenant info get --output json"
          ]
        },
        {
          "name": "mailboxCount",
          "category": "posture",
          "commands": [
            "m365 outlook report mailboxusagemailboxcount --period D30 --output json",
            "m365 outlook report mailboxusagedetail --period D30 --output json",
            "m365 outlook roomlist list --output json"
          ],
          "graph_fallback": "mailbox_count"
        },
        {
          "name": "mailboxQuotaStatus",
          "category": "posture",
          "commands": [
            "m365 outlook report mailboxusagequotastatusmailboxcounts --period D30 --output json"
          ]
        },
        {
          "name": "mailboxStorage",
          "category": "posture",
          "commands": [
            "m365 outlook report mailboxusagestorage --period D30 --output json"
          ]
        },
        {
          "name": "mailActivityCounts",
          "category": "posture",
          "commands": [
            "m365 outlook report mailactivitycounts --period D30 --output json"
          ]
        },
        {
          "name": "roomLists",
          "category": "posture",
          "commands": [
            "m365 outlook roomlist list --output json"
          ]
        }
      ]
    },
    "mailbox_forwarding": {
      "enabled": true,
      "description": "Mailbox forwarding settings and inbox rules per licensed user (BEC indicator: external forwarding, hide-from-user patterns).",
      "required_permissions": [
        "User.Read.All",
        "MailboxSettings.Read.All"
      ],
      "query_plan": [
        "users",
        "domains",
        "messageRules",
        "mailboxSettings"
      ]
    },
    "exchange_policy": {
      "enabled": true,
      "description": "Exchange transport, connector, domain, and mailbox forwarding policy posture",
      "required_permissions": [],
      "query_plan": [
        "transportRules",
        "inboundConnectors",
        "outboundConnectors",
        "acceptedDomains",
        "remoteDomains",
        "mailboxForwarding"
      ],
      "command_collectors": [
        {
          "name": "transportRules",
          "category": "policy",
          "commands": [
            "Get-TransportRule | Select-Object Name,State,Priority,Mode"
          ]
        },
        {
          "name": "inboundConnectors",
          "category": "policy",
          "commands": [
            "Get-InboundConnector | Select-Object Name,Enabled,ConnectorType"
          ]
        },
        {
          "name": "outboundConnectors",
          "category": "policy",
          "commands": [
            "Get-OutboundConnector | Select-Object Name,Enabled,ConnectorType"
          ]
        },
        {
          "name": "acceptedDomains",
          "category": "policy",
          "commands": [
            "Get-AcceptedDomain | Select-Object Name,DomainName,DomainType,Default"
          ]
        },
        {
          "name": "remoteDomains",
          "category": "policy",
          "commands": [
            "Get-RemoteDomain | Select-Object Name,DomainName,TrustedMailOutboundEnabled,AutoReplyEnabled"
          ]
        },
        {
          "name": "mailboxForwarding",
          "category": "policy",
          "commands": [
            "Get-EXOMailbox -ResultSize 50 | Select-Object DisplayName,PrimarySmtpAddress,ForwardingSmtpAddress,DeliverToMailboxAndForward"
          ]
        }
      ]
    }
  },
  "default_order": [
    "identity",
    "app_consent",
    "app_credentials",
    "security",
    "conditional_access",
    "defender",
    "service_health",
    "auth_methods",
    "reports_usage",
    "external_identity",
    "consent_policy",
    "cross_tenant_access",
    "dns_posture",
    "domains_hybrid",
    "licensing",
    "identity_governance",
    "intune",
    "intune_depth",
    "sharepoint",
    "sharepoint_access",
    "onedrive_posture",
    "power_platform",
    "sentinel_xdr",
    "defender_cloud_apps",
    "copilot_governance",
    "teams",
    "teams_policy",
    "purview",
    "ediscovery",
      "exchange",
      "exchange_policy",
      "mailbox_forwarding"
    ]
}
