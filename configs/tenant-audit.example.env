AZURE_TENANT_ID=<tenant-id>
AZURE_CLIENT_ID=<application-id>
AZURE_CLIENT_SECRET=<client-secret>
AZURE_ACCESS_TOKEN=<optional-graph-token>
AZURE_AUTHORITY=https://login.microsoftonline.com/
AZURE_GRAPH_SCOPE=https://graph.microsoft.com/.default
AZURE_GRAPH_SCOPES=Directory.Read.All,User.Read.All,Group.Read.All,SecurityEvents.Read.All

# Optional Microsoft 365 CLI app identifiers for command-based Exchange collection.
M365_CLI_APP_ID=
M365_CLI_CLIENT_ID=

AUDIT_OUTPUT_DIR=./audit-output
AUDIT_COLLECTORS=identity,security,intune,teams
AUDIT_SAMPLE_FILE=examples/sample_audit_bundle/sample_result.json
