{
  "presets": {
    "config-only": {
      "description": "Run configuration and posture collectors while skipping heavier export-style surfaces.",
      "include": [
        "identity",
        "app_consent",
        "conditional_access",
        "auth_methods",
        "external_identity",
        "consent_policy",
        "domains_hybrid",
        "licensing",
        "sharepoint",
        "teams"
      ],
      "exclude": [],
      "plane": "inventory"
    },
    "full": {
      "description": "Run the broad collector set intended for a first delegated-reader assessment.",
      "include": [
        "identity",
        "app_consent",
        "security",
        "conditional_access",
        "defender",
        "service_health",
        "auth_methods",
        "reports_usage",
        "external_identity",
        "consent_policy",
        "domains_hybrid",
        "licensing",
        "intune",
        "sharepoint",
        "sharepoint_access",
        "onedrive_posture",
        "teams"
      ],
      "exclude": [],
      "plane": "full"
    },
    "identity-only": {
      "description": "Limit collection to identities, roles, service principals, and app consent posture.",
      "include": [
        "identity",
        "app_consent"
      ],
      "exclude": [],
      "plane": "inventory"
    },
    "security-only": {
      "description": "Focus on identity security, alerting, Defender, and authentication posture surfaces.",
      "include": [
        "security",
        "conditional_access",
        "defender",
        "auth_methods",
        "identity_governance"
      ],
      "exclude": [],
      "plane": "full"
    }
  }
}
