#!/usr/bin/env bash
set -euo pipefail

CURRENT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${CURRENT_DIR}/load-local-auth.sh"
ROOT="$(cd "${CURRENT_DIR}/.." && pwd)"

PYTHON_BIN="${ROOT}/.venv/bin/python"
if [[ ! -x "${PYTHON_BIN}" ]]; then
  PYTHON_BIN="python3"
fi

exec env PYTHONPATH="${ROOT}/src" "${PYTHON_BIN}" -m auditex.cli guided-run "$@"
