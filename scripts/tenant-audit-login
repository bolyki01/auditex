#!/usr/bin/env bash
set -euo pipefail

CURRENT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${CURRENT_DIR}/load-local-auth.sh"

usage() {
  cat <<'USAGE'
Usage: tenant-audit-login [tenant-id-or-domain|organizations]

Defaults:
  tenant: organizations
Options:
  --help      Show this message.
  --reauth    Force a fresh browser sign-in flow.
  --browser   Browser command to launch (default: firefox).
  --m365      Sign in to Microsoft 365 CLI (m365) after Azure CLI login.
  --m365-app-id <app-id>
             App ID used for Microsoft 365 CLI browser auth.
USAGE
}

TENANT="organizations"
BROWSER_COMMAND="firefox"
M365_LOGIN=0
M365_APP_ID="${M365_CLI_APP_ID:-${M365_CLI_CLIENT_ID:-}}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help|-h)
      usage
      exit 0
      ;;
    --reauth)
      FORCE_REAUTH=1
      shift
      ;;
    --browser)
      BROWSER_COMMAND="${2:-firefox}"
      shift 2
      ;;
    --m365-app-id)
      M365_APP_ID="${2:-}"
      shift 2
      ;;
    --m365)
      M365_LOGIN=1
      shift
      ;;
    --*)
      echo "Unknown option: $1"
      usage
      exit 1
      ;;
    *)
      TENANT="${1}"
      shift
      ;;
  esac
done

FORCE_REAUTH="${FORCE_REAUTH:-0}"

if ! command -v az >/dev/null 2>&1; then
  echo "Azure CLI is not installed. Install it first:"
  echo "  brew install azure-cli"
  echo "  (Linux) curl -sL https://aka.ms/InstallAzureCLIDeb | sudo bash"
  exit 2
fi

if [[ "${FORCE_REAUTH}" -eq 1 ]]; then
  az logout >/dev/null 2>&1 || true
fi

if [[ -n "${BROWSER_COMMAND}" ]]; then
  export BROWSER="${BROWSER_COMMAND}"
fi

echo "Launching Azure login in ${BROWSER_COMMAND} for tenant: ${TENANT}"
az login --tenant "${TENANT}"

if [[ "${M365_LOGIN}" -eq 1 ]]; then
  if ! command -v m365 >/dev/null 2>&1; then
    echo "Microsoft 365 CLI is not installed. Install it first:"
    echo "  npm install -g @pnp/cli-microsoft365@latest"
    exit 3
  fi

  echo "Launching Microsoft 365 CLI login in ${BROWSER_COMMAND} for tenant: ${TENANT}"
  if [[ -n "${M365_APP_ID}" ]]; then
    export M365_CLI_APP_ID="${M365_APP_ID}"
  fi

  m365_login_cmd=(
    m365
    login
    --authType
    browser
    --tenant
    "${TENANT}"
    --output
    text
  )
  if [[ -n "${M365_APP_ID}" ]]; then
    m365_login_cmd+=(--appId "${M365_APP_ID}")
  fi
  if ! "${m365_login_cmd[@]}"; then
    if [[ -z "${M365_APP_ID}" ]] && [[ -z "${M365_CLI_APP_ID:-}" ]]; then
      echo "Exchange flow requires a Microsoft 365 CLI appId."
      echo "Provide one with --m365-app-id or set M365_CLI_APP_ID / M365_CLI_CLIENT_ID."
      echo "If this is a one-off environment, use 'm365 setup --scripting' first, then retry."
    fi
    exit 4
  fi
fi
